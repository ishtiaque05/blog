---
import BaseLayout from './BaseLayout.astro';
import CodeCopy from '../components/CodeCopy.astro';
import { formatDate } from '../lib/posts';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  prev?: CollectionEntry<'blog'>;
  next?: CollectionEntry<'blog'>;
}
const { post, prev, next } = Astro.props;
const base = import.meta.env.BASE_URL;
const words = post.body ? post.body.trim().split(/\s+/).length : 0;
const readMin = Math.max(1, Math.round(words / 200));
---
<BaseLayout title={post.data.title} description={post.data.description}>
  <article>
    <header class="post-head">
      <h1>{post.data.title}</h1>
      <div class="meta">
        <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
        <span>· {readMin} min read</span>
        {post.data.tags.map((t) => <a class="tag" href={`${base}tags/${t}/`}>{t}</a>)}
      </div>
    </header>
    <div class="prose">
      <slot />
    </div>
    <nav class="post-nav">
      {prev && <a href={`${base}posts/${prev.id}/`}>← {prev.data.title}</a>}
      {next && <a class="next" href={`${base}posts/${next.id}/`}>{next.data.title} →</a>}
    </nav>
  </article>
  <CodeCopy />
</BaseLayout>

<style>
  .post-head h1 { font-size: 1.6rem; margin-bottom: 0.5rem; }
  .post-head .meta { display: flex; flex-wrap: wrap; gap: 0.6rem; align-items: center; color: var(--muted); font-size: 0.8rem; margin-bottom: 1.5rem; }
  .post-nav { display: flex; justify-content: space-between; gap: 1rem; margin-top: 3rem; border-top: 1px solid var(--border); padding-top: 1.5rem; font-size: 0.85rem; }
  .post-nav .next { margin-left: auto; text-align: right; }
</style>
