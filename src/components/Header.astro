---
import ThemeToggle from './ThemeToggle.astro';
const base = import.meta.env.BASE_URL;
---
<header class="site-header">
  <div class="container bar">
    <a class="brand" href={base}>
      <span class="prompt">syed@dev</span>:<span class="path">~</span>$
    </a>
    <nav class="nav">
      <a href={base}>home</a>
      <a href={`${base}tags/`}>tags</a>
      <ThemeToggle />
    </nav>
  </div>
</header>

<style>
  .site-header { border-bottom: 1px solid var(--border); background: var(--bg); }
  .bar { display: flex; align-items: center; justify-content: space-between; padding-top: 1rem; padding-bottom: 1rem; }
  .brand { font-family: var(--font-mono); font-weight: 700; color: var(--text); }
  .brand .path { color: var(--cyan); }
  .nav { display: flex; align-items: center; gap: 1rem; font-size: 0.85rem; }
  .nav a { color: var(--muted); }
  .nav a:hover { color: var(--green); text-decoration: none; }
</style>
